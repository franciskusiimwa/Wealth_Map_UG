{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "install dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["install"]
    },
    {
      "label": "run dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "isBackground": true
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "npm",
      "args": ["run", "typecheck"]
    }
  ]
}
